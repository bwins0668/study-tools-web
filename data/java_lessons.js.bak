// ============================================================
// 実践編 第8章 — GUIアプリケーション
// ============================================================
{
  id: "jissen-8",
  book: "実践編",
  bookZh: "实践篇",
  chapter: 8,
  titleJa: "実践編 第8章 GUIアプリケーション",
  titleZh: "实践篇 第8章 GUI应用程序",
  subtitleJa: "Swing・レイアウト・イベント処理",
  subtitleZh: "Swing组件、布局管理器、事件处理",
  conceptJa: `<h3>GUIとは</h3>
<p>Graphical User Interface（グラフィカルユーザインタフェース）の略。ウィンドウ、ボタン、テキストフィールドなどの視覚的な部品（コンポーネント）を使ったアプリです。</p>

<h3>Swingライブラリ</h3>
<p>JavaのGUI作成に使う標準ライブラリです。<code>javax.swing</code>パッケージに含まれます。</p>
<p>主なコンポーネント：</p>
<table border="1" style="border-collapse:collapse;width:100%">
<tr><th>クラス</th><th>説明</th></tr>
<tr><td>JFrame</td><td>ウィンドウの枠</td></tr>
<tr><td>JButton</td><td>ボタン</td></tr>
<tr><td>JLabel</td><td>ラベル（テキスト表示）</td></tr>
<tr><td>JTextField</td><td>1行テキスト入力</td></tr>
<tr><td>JPanel</td><td>コンポーネントのまとめ用パネル</td></tr>
</table>

<h3>レイアウトマネージャ</h3>
<ul>
  <li><strong>FlowLayout</strong>：横に並べる（デフォルト）</li>
  <li><strong>BorderLayout</strong>：上下左右中央の5エリア</li>
  <li><strong>GridLayout</strong>：格子状に並べる</li>
</ul>

<h3>イベント処理</h3>
<p>ボタンクリックなどのイベントに応答するための仕組みです。</p>
<pre><code>JButton btn = new JButton("クリック");
btn.addActionListener(e -> {
    System.out.println("ボタンが押されました！");
});</code></pre>

<h3>注意</h3>
<p>GUIプログラムはSwingウィンドウを必要とするため、このサンドボックスでは表示できません。ローカルのIDEで実行してください。</p>`,

  conceptZh: `<h3>什么是GUI</h3>
<p>图形用户界面（Graphical User Interface）。用窗口、按钮、文本框等图形组件与用户交互的应用程序。</p>

<h3>Swing库</h3>
<p>Java标准的GUI库，在<code>javax.swing</code>包中。主要组件：</p>
<ul>
  <li><code>JFrame</code>：窗口框架</li>
  <li><code>JButton</code>：按钮</li>
  <li><code>JLabel</code>：标签（显示文字）</li>
  <li><code>JTextField</code>：单行文本输入</li>
</ul>

<h3>布局管理器（Layout Manager）</h3>
<p>控制组件在窗口中的排列方式：</p>
<ul>
  <li><strong>FlowLayout</strong>：从左到右排列</li>
  <li><strong>BorderLayout</strong>：上下左右中五个区域</li>
  <li><strong>GridLayout</strong>：网格排列</li>
</ul>

<h3>事件处理（Event Handling）</h3>
<p>用<code>ActionListener</code>监听按钮点击等用户操作，通过Lambda表达式简化代码：</p>
<pre><code>button.addActionListener(e -> {
    System.out.println("按钮被点击了！");
});</code></pre>

<h3>注意</h3>
<p>GUI程序需要显示Swing窗口，在此沙盒中无法运行。请在本地IDE（如Eclipse、IntelliJ）中执行。</p>`,

  analogy: "🖥️ Swing就像搭积木：JFrame是积木桶（容器），JButton、JLabel是不同形状的积木（组件），LayoutManager是「怎么排列积木」的规则，ActionListener是「按下某块积木会发生什么」的机关。",

  codeExample: `// GUIアプリケーションのコード例（ローカルIDEで実行してください）
// GUI程序示例（请在本地IDE中运行）
// ※ このサンドボックスではGUIウィンドウは表示できません

import javax.swing.*;
import java.awt.*;

public class Main {
    public static void main(String[] args) {
        // SwingのUIはEDT（Event Dispatch Thread）で作成する
        SwingUtilities.invokeLater(() -> {
            // フレームの作成 / 创建窗口
            JFrame frame = new JFrame("簡単な電卓 / Simple Calculator");
            frame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
            frame.setSize(300, 200);
            
            // パネルとレイアウト / 面板与布局
            JPanel panel = new JPanel(new GridLayout(3, 2, 5, 5));
            
            JLabel label1 = new JLabel("数値A:");
            JTextField field1 = new JTextField("10");
            JLabel label2 = new JLabel("数値B:");
            JTextField field2 = new JTextField("5");
            JLabel resultLabel = new JLabel("結果: -");
            JButton calcBtn = new JButton("計算");
            
            panel.add(label1); panel.add(field1);
            panel.add(label2); panel.add(field2);
            panel.add(resultLabel); panel.add(calcBtn);
            
            // イベント処理 / 事件处理
            calcBtn.addActionListener(e -> {
                try {
                    int a = Integer.parseInt(field1.getText());
                    int b = Integer.parseInt(field2.getText());
                    resultLabel.setText("結果: " + (a + b));
                } catch (NumberFormatException ex) {
                    resultLabel.setText("エラー: 数値を入力してください");
                }
            });
            
            frame.add(panel);
            frame.setVisible(true);  // ウィンドウを表示
        });
        
        System.out.println("GUIウィンドウのコード構造を確認できます");
        System.out.println("実際の実行にはEclipseやIntelliJ IDEAをご使用ください");
        System.out.println("\\n=== Swingの主要クラス ===");
        System.out.println("JFrame   - ウィンドウフレーム / 窗口框架");
        System.out.println("JButton  - ボタン / 按钮");
        System.out.println("JLabel   - テキスト表示 / 文字标签");
        System.out.println("JPanel   - パネル（コンテナ）/ 面板容器");
        System.out.println("JTextField - 1行入力 / 单行文本输入");
    }
}`,
  codeTitle: "GUIアプリの構造（Swing）",

  quizList: [
    {
      question: "JFrameとは何ですか？",
      questionZh: "JFrame是什么？",
      options: ["ボタンコンポーネント", "アプリケーションのウィンドウフレーム", "テキスト入力フィールド", "レイアウトマネージャ"],
      answerIdx: 1,
      hint: "GUIアプリの「箱」の役割をします / 是GUI应用程序的「窗口容器」。"
    },
    {
      question: "BorderLayoutが分割する領域の数は？",
      questionZh: "BorderLayout将窗口分为多少个区域？",
      options: ["3", "4", "5", "9"],
      answerIdx: 2,
      hint: "North, South, East, West, Center の5エリアです / 分为North, South, East, West, Center共5个区域。"
    },
    {
      question: "ボタンクリックのイベントを処理するインタフェースは？",
      questionZh: "处理按钮点击事件的接口是什么？",
      options: ["ClickListener", "ActionListener", "MouseListener", "EventHandler"],
      answerIdx: 1,
      hint: "addActionListener()メソッドで登録します / 通过addActionListener()方法注册。"
    }
  ],

  vocabList: [
    { term: "GUI", zh: "图形用户界面", desc: "ウィンドウやボタンなどのグラフィカルな部品を使ったユーザインタフェース。" },
    { term: "コンポーネント (component)", zh: "组件", desc: "GUIを構成する部品（JButton, JLabel, JTextField など）。" },
    { term: "イベント (event)", zh: "事件", desc: "ボタンクリックやキー入力など、ユーザの操作によって発生するもの。" },
    { term: "レイアウトマネージャ", zh: "布局管理器", desc: "コンポーネントの配置方法を管理するクラス（FlowLayout, BorderLayout など）。" }
  ]
},

// ============================================================
// 実践編 第9章 — 図形描画とマウスイベント
// ============================================================
{
  id: "jissen-9",
  book: "実践編",
  bookZh: "实践篇",
  chapter: 9,
  titleJa: "実践編 第9章 図形描画とマウスイベント",
  titleZh: "实践篇 第9章 图形绘制与鼠标事件",
  subtitleJa: "Graphics2D・paintComponent・MouseListener",
  subtitleZh: "Graphics2D、绘图方法、鼠标监听器",
  conceptJa: `<h3>Javaの描画の仕組み</h3>
<p>SwingのJPanelを拡張して<code>paintComponent(Graphics g)</code>をオーバーライドすることで描画を行います。</p>
<pre><code>class DrawPanel extends JPanel {
    @Override
    protected void paintComponent(Graphics g) {
        super.paintComponent(g);
        g.setColor(Color.RED);
        g.fillRect(50, 50, 100, 80);  // 塗りつぶし四角形
        g.drawOval(200, 50, 80, 80);  // 楕円（枠のみ）
        g.drawLine(0, 0, 300, 300);   // 直線
    }
}</code></pre>

<h3>Graphics2Dクラス</h3>
<p>GraphicsをキャストしてGraphics2Dにすることで、より多彩な描画が可能：</p>
<pre><code>Graphics2D g2 = (Graphics2D) g;
g2.setStroke(new BasicStroke(3));  // 線の太さ
g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING,
                    RenderingHints.VALUE_ANTIALIAS_ON);  // アンチエイリアス</code></pre>

<h3>座標系</h3>
<p>左上が(0,0)で、右がX軸正方向、下がY軸正方向です。</p>

<h3>マウスイベント</h3>
<p><code>MouseListener</code>インタフェースで5つのイベントを処理できます：</p>
<ul>
  <li><code>mouseClicked</code>：クリック</li>
  <li><code>mousePressed</code>：ボタンを押した</li>
  <li><code>mouseReleased</code>：ボタンを離した</li>
  <li><code>mouseEntered</code>：コンポーネントにマウスが入った</li>
  <li><code>mouseExited</code>：コンポーネントからマウスが出た</li>
</ul>

<h3>注意</h3>
<p>描画プログラムはGUIウィンドウが必要なため、このサンドボックスでは直接実行できません。ローカルIDEをご利用ください。</p>`,

  conceptZh: `<h3>Java绘图机制</h3>
<p>继承JPanel并覆盖<code>paintComponent(Graphics g)</code>方法来绘图。每次窗口需要重绘时，此方法自动被调用。</p>

<h3>常用绘图方法</h3>
<table border="1" style="border-collapse:collapse;width:100%">
<tr><th>方法</th><th>说明</th></tr>
<tr><td>drawLine(x1,y1,x2,y2)</td><td>画直线</td></tr>
<tr><td>drawRect(x,y,w,h)</td><td>画矩形边框</td></tr>
<tr><td>fillRect(x,y,w,h)</td><td>填充矩形</td></tr>
<tr><td>drawOval(x,y,w,h)</td><td>画椭圆边框</td></tr>
<tr><td>fillOval(x,y,w,h)</td><td>填充椭圆</td></tr>
<tr><td>drawString(s,x,y)</td><td>在(x,y)画文字</td></tr>
</table>

<h3>坐标系</h3>
<p>原点(0,0)在左上角，X轴向右，Y轴向下（与数学坐标系Y轴相反！）。</p>

<h3>鼠标事件（MouseListener）</h3>
<p>实现<code>MouseListener</code>接口来响应鼠标操作：点击、按下、释放、进入、离开。</p>

<h3>注意</h3>
<p>绘图程序需要GUI窗口，在此沙盒中无法直接运行，请使用本地IDE。</p>`,

  analogy: "🎨 paintComponent就像画布上的「重新绘制指令」：每次窗口需要更新（遮挡、缩放等），Java就自动调用这个方法重画一遍。鼠标监听器就像给画布装了「传感器」，感应鼠标的各种动作。",

  codeExample: `// 図形描画の概念デモ（コンソールでASCIIアートを描画）
// 图形绘制概念示例（在控制台绘制ASCII艺术）

public class Main {
    public static void main(String[] args) {
        System.out.println("=== ASCII図形描画デモ ===");
        System.out.println("（実際のJava Graphics2Dは本地IDEで実行）");
        System.out.println();
        
        // 四角形を描く / 绘制矩形
        drawRect(10, 4);
        System.out.println();
        
        // 三角形を描く / 绘制三角形
        drawTriangle(7);
        System.out.println();
        
        // 円を近似描画 / 近似圆形
        drawCircle(8);
    }
    
    // ASCII四角形 / ASCII矩形
    static void drawRect(int width, int height) {
        System.out.println("矩形 (" + width + "x" + height + "):");
        for (int y = 0; y < height; y++) {
            for (int x = 0; x < width; x++) {
                if (y == 0 || y == height-1 || x == 0 || x == width-1) {
                    System.out.print("*");
                } else {
                    System.out.print(" ");
                }
            }
            System.out.println();
        }
    }
    
    // ASCII三角形 / ASCII三角形
    static void drawTriangle(int height) {
        System.out.println("三角形 (高さ=" + height + "):");
        for (int i = 1; i <= height; i++) {
            for (int s = height - i; s > 0; s--) System.out.print(" ");
            for (int j = 0; j < 2*i-1; j++) System.out.print("*");
            System.out.println();
        }
    }
    
    // ASCII円 / ASCII圆形
    static void drawCircle(int radius) {
        System.out.println("円 (半径≈" + radius/2 + "):");
        for (int y = -radius/2; y <= radius/2; y++) {
            for (int x = -radius; x <= radius; x++) {
                double d = (double)(x*x)/4 + (double)(y*y);
                if (Math.abs(d - (double)(radius*radius)/4) < radius*0.7) {
                    System.out.print("*");
                } else {
                    System.out.print(" ");
                }
            }
            System.out.println();
        }
    }
}`,
  codeTitle: "図形描画の概念（コンソール版）",

  quizList: [
    {
      question: "Java Swingで描画を行うために override するメソッドは？",
      questionZh: "在Java Swing中，用于绘图需要覆盖的方法是？",
      options: ["draw()", "paintComponent(Graphics g)", "render()", "display()"],
      answerIdx: 1,
      hint: "JPanelを継承したクラスでこのメソッドをオーバーライドします / 在继承JPanel的类中覆盖此方法。"
    },
    {
      question: "Javaの画面座標で、Y軸の正方向はどちらですか？",
      questionZh: "Java屏幕坐标中，Y轴正方向是哪里？",
      options: ["上向き", "下向き", "右向き", "左向き"],
      answerIdx: 1,
      hint: "左上が原点(0,0)で、Y軸は下方向が正です（数学とは逆！）/ 左上为原点，Y轴向下为正（与数学坐标系相反！）"
    },
    {
      question: "g.fillRect(10, 20, 100, 50) で塗りつぶされる形状は？",
      questionZh: "g.fillRect(10, 20, 100, 50) 填充的是什么形状？",
      options: ["円", "三角形", "四角形（幅100、高さ50）", "直線"],
      answerIdx: 2,
      hint: "fillRect(x, y, 幅, 高さ) / fillRect(x, y, 宽度, 高度)"
    }
  ],

  vocabList: [
    { term: "paintComponent", zh: "绘图方法", desc: "JPanel を継承して描画するためにオーバーライドするメソッド。" },
    { term: "Graphics2D", zh: "2D图形对象", desc: "Graphicsの拡張版。より高機能な描画ができる。" },
    { term: "MouseListener", zh: "鼠标监听器", desc: "マウスイベント（クリック、移動など）を処理するインタフェース。" }
  ]
},

// ============================================================
// 実践編 第10章 — ネットワーク
// ============================================================
{
  id: "jissen-10",
  book: "実践編",
  bookZh: "实践篇",
  chapter: 10,
  titleJa: "実践編 第10章 ネットワーク",
  titleZh: "实践篇 第10章 网络编程",
  subtitleJa: "Socket・ServerSocket・TCP通信",
  subtitleZh: "Socket、ServerSocket、TCP通信",
  conceptJa: `<h3>Javaのネットワークプログラミング</h3>
<p><code>java.net</code>パッケージを使ってTCP/IP通信を実装できます。</p>

<h3>基本概念</h3>
<ul>
  <li><strong>IPアドレス</strong>：ネットワーク上のコンピュータの住所</li>
  <li><strong>ポート番号</strong>：同じコンピュータ内でアプリを識別する番号（0〜65535）</li>
  <li><strong>TCP</strong>：信頼性の高い通信プロトコル（データの到達を保証）</li>
</ul>

<h3>サーバー側</h3>
<pre><code>ServerSocket serverSocket = new ServerSocket(8080);
Socket socket = serverSocket.accept();  // クライアントの接続を待つ

// データの受信
BufferedReader in = new BufferedReader(
    new InputStreamReader(socket.getInputStream()));
String message = in.readLine();

// データの送信
PrintWriter out = new PrintWriter(socket.getOutputStream(), true);
out.println("こんにちは！");</code></pre>

<h3>クライアント側</h3>
<pre><code>Socket socket = new Socket("localhost", 8080);  // サーバーに接続

PrintWriter out = new PrintWriter(socket.getOutputStream(), true);
out.println("Hello Server!");  // 送信

BufferedReader in = new BufferedReader(
    new InputStreamReader(socket.getInputStream()));
String response = in.readLine();  // 受信</code></pre>

<h3>注意</h3>
<p>ネットワークプログラムはサーバーとクライアントの2つのプログラムが必要です。このサンドボックスでは直接実行できませんが、コード構造を確認できます。</p>`,

  conceptZh: `<h3>Java网络编程</h3>
<p>使用<code>java.net</code>包实现TCP/IP通信。</p>

<h3>基本概念</h3>
<ul>
  <li><strong>IP地址</strong>：网络上计算机的地址</li>
  <li><strong>端口号</strong>：同一台计算机上区分不同应用的编号（0-65535）</li>
  <li><strong>TCP</strong>：可靠的传输协议，保证数据一定能到达</li>
</ul>

<h3>服务器端</h3>
<pre><code>ServerSocket serverSocket = new ServerSocket(8080);
Socket socket = serverSocket.accept();  // 等待客户端连接

// 接收数据
BufferedReader in = new BufferedReader(
    new InputStreamReader(socket.getInputStream()));
String message = in.readLine();

// 发送数据
PrintWriter out = new PrintWriter(socket.getOutputStream(), true);
out.println("你好！");</code></pre>

<h3>客户端</h3>
<pre><code>Socket socket = new Socket("localhost", 8080);  // 连接到服务器

PrintWriter out = new PrintWriter(socket.getOutputStream(), true);
out.println("Hello Server!");  // 发送

BufferedReader in = new BufferedReader(
    new InputStreamReader(socket.getInputStream()));
String response = in.readLine();  // 接收</code></pre>

<h3>注意</h3>
<p>网络程序需要同时运行服务器和客户端两个程序，在此沙盒中无法直接演示，但可以理解代码结构。</p>`,

  analogy: "📞 网络编程就像打电话：ServerSocket是「装了电话的服务台」，等待来电（accept）。Socket是「电话连线」。InputStream/OutputStream是电话里的「听筒和话筒」，负责接收和发送信息。IP地址+端口号是「电话号码+分机号」。",

  codeExample: `// ネットワーク通信の概念デモ（実際の通信はローカルIDEで）
// 网络通信概念示例（实际通信请在本地IDE中演示）

public class Main {
    public static void main(String[] args) {
        System.out.println("=== ネットワーク通信の概念 ===");
        System.out.println();
        
        // URL処理の例（java.netを使用）
        System.out.println("// サーバー側のコード構造:");
        System.out.println("// ServerSocket server = new ServerSocket(8080);");
        System.out.println("// Socket client = server.accept(); // 接続待機");
        System.out.println("// BufferedReader in = new BufferedReader(");
        System.out.println("//     new InputStreamReader(client.getInputStream()));");
        System.out.println("// String msg = in.readLine();");
        System.out.println();
        System.out.println("// クライアント側のコード構造:");
        System.out.println("// Socket socket = new Socket(\"localhost\", 8080);");
        System.out.println("// PrintWriter out = new PrintWriter(socket.getOutputStream(), true);");
        System.out.println("// out.println(\"Hello!\");");
        System.out.println();
        
        // IPアドレスとポートの概念示説
        System.out.println("=== IPアドレスとポートの例 ===");
        String[][] portExamples = {
            {"HTTP", "80"},
            {"HTTPS", "443"},
            {"SSH", "22"},
            {"FTP", "21"},
            {"MySQL", "3306"}
        };
        
        System.out.printf("%-10s %s%n", "プロトコル", "ポート番号");
        System.out.println("-".repeat(20));
        for (String[] p : portExamples) {
            System.out.printf("%-10s %s%n", p[0], p[1]);
        }
        
        // 簡単なエコーサーバーシミュレーション
        System.out.println("\\n=== エコーサーバーシミュレーション ===");
        String[] messages = {"Hello Server", "データを送信", "接続終了"};
        for (String msg : messages) {
            System.out.println("クライアント → サーバー: " + msg);
            System.out.println("サーバー → クライアント: [Echo] " + msg);
            System.out.println();
        }
    }
}`,
