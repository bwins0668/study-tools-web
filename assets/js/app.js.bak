// SQL Output Tab Switching
function switchSqlOutputTab(tab) {
  const tableBtn = document.getElementById("sql-tab-table");
  const visualBtn = document.getElementById("sql-tab-visual");
  const outputBody = document.getElementById("output-body");
  const joinVisual = document.getElementById("sql-join-visual-container");

  if (tab === 'table') {
    tableBtn.classList.add("active");
    visualBtn.classList.remove("active");
    outputBody.style.display = "block";
    joinVisual.style.display = "none";
  } else {
    tableBtn.classList.remove("active");
    visualBtn.classList.add("active");
    outputBody.style.display = "none";
    joinVisual.style.display = "block";
  }
}

