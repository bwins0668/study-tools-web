// SQL JOIN Regular Expression Parser
function parseSqlJoin(sql) {
  const joinRegex = /from\s+(\w+)(?:\s+\w+)?\s+(?:(inner|left|right)\s+)?join\s+(\w+)(?:\s+\w+)?\s+on\s+([^;\r\n]+)/i;
  const match = sql.match(joinRegex);
  if (match) {
    let leftTable = match[1];
    let joinType = match[2] ? match[2].toUpperCase() : 'INNER';
    let rightTable = match[3];
    let onCondition = match[4].trim();
    return {
      leftTable,
      joinType,
      rightTable,
      onCondition
    };
  }
  return null;
}

// Render SQL JOIN Venn and Tree Visual
function renderSqlJoinVisual(joinInfo, outputRowCount) {
  const container = document.getElementById("sql-join-visual-container");
  if (!container) return;

  let leftTotal = 10;
  let rightTotal = 10;
  try {
    const leftCountRes = sqlEngine.execute(`SELECT COUNT(*) FROM ${joinInfo.leftTable}`);
    if (leftCountRes.success && leftCountRes.rows.length > 0) {
      leftTotal = leftCountRes.rows[0][0];
    }
    const rightCountRes = sqlEngine.execute(`SELECT COUNT(*) FROM ${joinInfo.rightTable}`);
    if (rightCountRes.success && rightCountRes.rows.length > 0) {
      rightTotal = rightCountRes.rows[0][0];
    }
  } catch (e) {
    console.error("Fetch join tables row count error:", e);
  }

  const joinTypeClass = joinInfo.joinType.toLowerCase() + '-join';
  
  const vennHtml = `
    <div class="sql-visual-section">
      <div class="sql-visual-title"><i class="fa-solid fa-circle-half-stroke"></i> 扈ｴ諱ｩ蝗ｾ閨疲磁蜈ｳ邉ｻ (Venn Diagram)</div>
      <div class="venn-wrapper">
        <svg class="venn-svg ${joinTypeClass}" viewBox="0 0 280 160">
          <defs>
            <clipPath id="intersect-clip">
              <circle cx="100" cy="80" r="60" />
            </clipPath>
          </defs>
          <circle cx="100" cy="80" r="60" class="venn-circle left-table" />
          <circle cx="180" cy="80" r="60" class="venn-circle right-table" />
          <circle cx="180" cy="80" r="60" class="venn-intersect" clip-path="url(#intersect-clip)" style="fill: transparent; fill-opacity: 0.15; stroke-width: 0;" />
          <text x="70" y="83" fill="#fff" font-size="11" font-weight="700" text-anchor="middle">${joinInfo.leftTable}</text>
          <text x="70" y="98" fill="var(--text-muted)" font-size="9" text-anchor="middle">(${leftTotal} 陦・</text>
          
          <text x="210" y="83" fill="#fff" font-size="11" font-weight="700" text-anchor="middle">${joinInfo.rightTable}</text>
          <text x="210" y="98" fill="var(--text-muted)" font-size="9" text-anchor="middle">(${rightTotal} 陦・</text>
          
          <text x="140" y="30" fill="var(--neon-cyan)" font-size="12" font-weight="800" text-anchor="middle">${joinInfo.joinType} JOIN</text>
        </svg>
      </div>
    </div>
  `;

  const treeHtml = `
    <div class="sql-visual-section">
      <div class="sql-visual-title"><i class="fa-solid fa-network-wired"></i> 謨ｰ謐ｮ豬・JOIN 譬・(Dataflow JOIN Tree)</div>
      <div class="join-tree">
        <div class="join-tree-row">
          <div class="tree-node">
            <div class="tree-node-title">蟾ｦ陦ｨ: ${joinInfo.leftTable}</div>
            <div class="tree-node-value">${leftTotal} 陦・/div>
          </div>
          <div class="tree-node">
            <div class="tree-node-title">蜿ｳ陦ｨ: ${joinInfo.rightTable}</div>
            <div class="tree-node-value">${rightTotal} 陦・/div>
          </div>
        </div>
        <div class="tree-arrow"><i class="fa-solid fa-angle-down"></i></div>
        <div class="tree-condition-node">
          <div class="tree-condition-inner">ON<br>譚｡莉ｶ</div>
        </div>
        <div style="font-size: 11px; font-family:'Fira Code', monospace; color: var(--text-muted); margin: -4px 0 6px 0;">
          ${joinInfo.onCondition}
        </div>
        <div class="tree-arrow"><i class="fa-solid fa-angle-down"></i></div>
        <div class="join-tree-row" style="justify-content: center;">
          <div class="tree-node highlight-node">
            <div class="tree-node-title" style="color: var(--neon-cyan)">蜷亥ｹｶ扈捺棡陦梧焚</div>
            <div class="tree-node-value" style="color: var(--neon-cyan)">${outputRowCount} 陦・/div>
          </div>
        </div>
      </div>
    </div>
  `;

  container.innerHTML = vennHtml + treeHtml;
}

