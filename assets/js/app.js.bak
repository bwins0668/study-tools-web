    8: ["逅・ｸ・ｽｯ莉ｶ蠑蜿醍函蜻ｽ蜻ｨ譛滓ｵ∫ｨ句推髦ｶ谿ｵ莉ｻ蜉｡", "蟇ｹ豈皮大ｸ・ｼ蜿第ｨ｡蝙倶ｸ取撫謐ｷ蠑蜿第ｨ｡蝙・, "逅・ｸ・BS蟾･菴懷・隗｣扈捺桷荳惨LA蜊剰ｮｮ謖・・],
    9: ["莠・ｧ｣B/S蜥訓/L雍｢蜉｡謚･陦ｨ莉･蜿願ｮ｡邂礼寤莠丞ｹｳ陦｡轤ｹ", "逅・ｧ｣蟾･荳壻ｺｧ譚・ｸ手送菴懈揀逧・ｿ晄侃闌・峩", "蛹ｺ蛻・､門桁蜷亥酔(隸ｷ雍・蜥悟患蜉｡豢ｾ驕｣逧・玄蛻ｫ"],
    10: ["謗梧升SWOT蛻・梵縲・C蛻・梵 and PPM莠ｧ蜩∫洸髦ｵ蛻貞・", "逅・ｧ｣莨∽ｸ夊ｵ・ｺ占ｧ・・(ERP)蜥御ｾ帛ｺ秘得邂｡逅・SCM)讎ょｿｵ", "莠・ｧ｣謨ｰ蟄怜喧霓ｬ蝙・DX)逧・渕譛ｬ讎ょｿｵ"]
  };
  
  // Use lesson.chapterId to load chapter-specific checklist for all sub-sections
  const curItems = items[lesson.chapterId] || ["隶､逵溷ｭｦ荵遶闃る㍾隕∵ｦょｿｵ", "螳梧・隸ｾ蜷守ｻ・ｹ蟆乗ｵ・];
  checklistBody.innerHTML = curItems.map(item => `
    <div class="checklist-item">
      <i class="fa-solid fa-circle-check"></i>
      <span>${item}</span>
    </div>
  `).join("");
}

// Dynamic Flashcards Loader & Controller
// Dynamic Flashcards Loader & Controller
function initFlashcards(lessonId) {
  // Reset time offset and mode when loading subjects/lessons if desired, but let's keep it persistent.
  if (flashcardMode === 'anki') {
    buildAnkiQueue();
    renderAnkiCard();
    return;
  }

  let cards = [];
  if (currentSubject === 'itpass') {
    const lesson = IT_PASSPORT_LESSONS.find(l => l.id === lessonId);
    cards = (lesson && lesson.vocabList) ? lesson.vocabList : [];
  } else if (currentSubject === 'sg') {
    const lesson = (typeof SG_LESSONS !== 'undefined') ? SG_LESSONS.find(l => l.id === lessonId) : null;
    cards = (lesson && lesson.vocabList) ? lesson.vocabList : [];
  } else if (currentSubject === 'sql') {
    const lesson = (typeof SQL_LESSONS !== 'undefined') ? SQL_LESSONS.find(l => l.id === lessonId) : null;
    cards = (lesson && lesson.vocabList) ? lesson.vocabList : [];
  }
  
  if (cards.length === 0) {
    const defaultTerm = currentSubject === 'sql' ? "SQL" : (currentSubject === 'sg' ? "諠・ｱ繧ｻ繧ｭ繝･繝ｪ繝・ぅ" : "IT繝代せ繝昴・繝・);
    cards = [{ ja: defaultTerm, zh: defaultTerm, desc: "譬ｸ蠢・惘隸ｭ讎ょｿｵ蟄ｦ荵蜊｡迚・・ }];
  }

  currentFlashcardIdx = 0;
  isFlashcardFlipped = false;
  
  renderFlashcard(cards);
}

function initSgFlashcards(lessonId) {
  initFlashcards(lessonId);
}

function renderFlashcard(cards) {
  const cardElement = document.getElementById("flashcard-element");
  if (!cardElement) return;
  
  cardElement.classList.remove("flipped");
  isFlashcardFlipped = false;
  
  // Controls display
  const chapterControls = document.getElementById("fc-chapter-controls");
  const ankiControls = document.getElementById("fc-anki-controls");
  if (chapterControls) chapterControls.style.display = "flex";
  if (ankiControls) ankiControls.style.display = "none";

  if (!cards || cards.length === 0) {
    document.getElementById("fc-ja-term").innerText = "證よ裏隸榊今";
    document.getElementById("fc-zh-term").innerText = "No cards";
    document.getElementById("fc-desc").innerText = "蠖灘燕遶闃よｲ｡譛芽ｯ榊今縲・;
    document.getElementById("fc-counter").innerText = "0 / 0";
    return;
  }
  
  const currentCard = cards[currentFlashcardIdx];
  
  document.getElementById("fc-ja-term").innerText = currentCard.ja;
  document.getElementById("fc-zh-term").innerText = currentCard.zh;
  document.getElementById("fc-desc").innerText = currentCard.desc;
  
  document.getElementById("fc-counter").innerText = `${currentFlashcardIdx + 1} / ${cards.length}`;
}

function flipFlashcard() {
  const cardElement = document.getElementById("flashcard-element");
  isFlashcardFlipped = !isFlashcardFlipped;
  cardElement.classList.toggle("flipped", isFlashcardFlipped);
  
  if (flashcardMode === 'anki') {
    const ankiControls = document.getElementById("fc-anki-controls");
    if (ankiControls) {
      ankiControls.style.display = isFlashcardFlipped ? "flex" : "none";
    }
  }
}

function prevFlashcard() {
  if (flashcardMode === 'anki') return;
  let cards = [];
  if (currentSubject === 'itpass') {
    const lesson = IT_PASSPORT_LESSONS.find(l => l.id === currentItPassLessonId);
    cards = (lesson && lesson.vocabList) ? lesson.vocabList : [];
  } else if (currentSubject === 'sg') {
    const lesson = (typeof SG_LESSONS !== 'undefined') ? SG_LESSONS.find(l => l.id === currentSgLessonId) : null;
    cards = (lesson && lesson.vocabList) ? lesson.vocabList : [];
  } else if (currentSubject === 'sql') {
    const lesson = (typeof SQL_LESSONS !== 'undefined') ? SQL_LESSONS.find(l => l.id === currentLessonId) : null;
    cards = (lesson && lesson.vocabList) ? lesson.vocabList : [];
  }
  if (cards.length === 0) return;
  
  currentFlashcardIdx = (currentFlashcardIdx - 1 + cards.length) % cards.length;
  renderFlashcard(cards);
}

function nextFlashcard() {
  if (flashcardMode === 'anki') return;
  let cards = [];
  if (currentSubject === 'itpass') {
    const lesson = IT_PASSPORT_LESSONS.find(l => l.id === currentItPassLessonId);
    cards = (lesson && lesson.vocabList) ? lesson.vocabList : [];
  } else if (currentSubject === 'sg') {
    const lesson = (typeof SG_LESSONS !== 'undefined') ? SG_LESSONS.find(l => l.id === currentSgLessonId) : null;
    cards = (lesson && lesson.vocabList) ? lesson.vocabList : [];
  } else if (currentSubject === 'sql') {
    const lesson = (typeof SQL_LESSONS !== 'undefined') ? SQL_LESSONS.find(l => l.id === currentLessonId) : null;
    cards = (lesson && lesson.vocabList) ? lesson.vocabList : [];
  }
  if (cards.length === 0) return;
  
  currentFlashcardIdx = (currentFlashcardIdx + 1) % cards.length;
  renderFlashcard(cards);
}

/* ==================== ANKI SPACED REPETITION CORE IMPLEMENTATION ==================== */

function loadAnkiCardsState() {
  const key = `anki_flashcards_state_${currentSubject}`;
  try {
    return JSON.parse(localStorage.getItem(key)) || {};
  } catch (e) {
    return {};
  }
}

function saveAnkiCardsState(state) {
  const key = `anki_flashcards_state_${currentSubject}`;
  localStorage.setItem(key, JSON.stringify(state));
}

function getAllVocabulary() {
  let lessons = [];
  if (currentSubject === 'itpass') {
    lessons = IT_PASSPORT_LESSONS;
  } else if (currentSubject === 'sg') {
    lessons = (typeof SG_LESSONS !== 'undefined') ? SG_LESSONS : [];
  }
  
  let wordsMap = new Map();
  lessons.forEach(l => {
    if (l.vocabList) {
      l.vocabList.forEach(v => {
        if (v.ja && !wordsMap.has(v.ja)) {
          wordsMap.set(v.ja, v);
        }
      });
    }
  });
  return Array.from(wordsMap.values());
}

function buildAnkiQueue() {
  const allWords = getAllVocabulary();
  const state = loadAnkiCardsState();
  const now = Date.now() + simulatedTimeOffset;
  
  let queue = [];
  allWords.forEach(w => {
    const cardState = state[w.ja] || {
      interval: 0,
      repetition: 0,
      efactor: 2.5,
      nextReview: 0
    };
    
    // Anki logic:
    // 1. New cards (interval === 0)
    // 2. Scheduled reviews (interval > 0 AND nextReview <= now)
    if (cardState.interval === 0 || cardState.nextReview <= now) {
      queue.push({
        ...w,
        state: cardState
      });
    }
  });
  
  // Sort: prioritize review items (interval > 0) over new items (interval === 0)
  queue.sort((a, b) => {
    if (a.state.interval > 0 && b.state.interval === 0) return -1;
    if (a.state.interval === 0 && b.state.interval > 0) return 1;
    return a.state.nextReview - b.state.nextReview;
  });
  
  ankiQueue = queue;
  ankiCurrentIdx = 0;
}

function renderAnkiCard() {
  const cardElement = document.getElementById("flashcard-element");
  if (!cardElement) return;
  
  cardElement.classList.remove("flipped");
  isFlashcardFlipped = false;
  
  const chapterControls = document.getElementById("fc-chapter-controls");
  const ankiControls = document.getElementById("fc-anki-controls");
  if (chapterControls) chapterControls.style.display = "none";
  if (ankiControls) ankiControls.style.display = "none"; // Hide until flipped

  if (ankiQueue.length === 0) {
    document.getElementById("fc-ja-term").innerText = "螟堺ｹ蜈ｨ驛ｨ螳梧・・Å沁・;
    document.getElementById("fc-zh-term").innerText = "Congratulations!";
    document.getElementById("fc-desc").innerText = "莉頑律髴隕∝､堺ｹ蜥悟ｭｦ荵逧・ｯ肴ｱ・ｷｲ蜈ｨ驛ｨ謳槫ｮ壹りｯｷ譏主､ｩ蜀肴擂・梧・謗ｨ霑幄ｰ・ｯ墓慮髣ｴ霑幄｡梧ｵ玖ｯ包ｼ・;
    document.getElementById("fc-counter").innerText = "0 / 0";
    return;
  }
  
  const currentCard = ankiQueue[ankiCurrentIdx];
  let badgeText = " [譁ｰ隸江";
  if (currentCard.state && currentCard.state.interval > 0) {
    badgeText = ` [螟堺ｹ荳ｭﾂｷ髣ｴ髫・{currentCard.state.interval}螟ｩ]`;
  }
  
  document.getElementById("fc-ja-term").innerText = currentCard.ja + badgeText;
  document.getElementById("fc-zh-term").innerText = currentCard.zh;
  document.getElementById("fc-desc").innerText = currentCard.desc;
  
  document.getElementById("fc-counter").innerText = `Anki 蜑ｩ菴・ ${ankiQueue.length} 隸港;
}

function switchFlashcardMode(mode) {
  flashcardMode = mode;
  
  const chapterBtn = document.getElementById("fc-mode-chapter");
  const ankiBtn = document.getElementById("fc-mode-anki");
  const debugBar = document.getElementById("anki-debug-bar");
  const descBox = document.getElementById("fc-desc-box");
  
  if (chapterBtn) chapterBtn.classList.toggle("active", mode === 'chapter');
  if (ankiBtn) ankiBtn.classList.toggle("active", mode === 'anki');
  
  if (mode === 'anki') {
    if (debugBar) debugBar.style.display = "flex";
    if (descBox) descBox.innerHTML = `<span>譎ｺ閭ｽ Anki 螟堺ｹ讓｡蠑擾ｼ亥・蠎楢ｯ肴ｱ・ｸ占ｿ幄ｮｰ蠢・ｼ会ｼ・/span>`;
    buildAnkiQueue();
    renderAnkiCard();
  } else {
    if (debugBar) debugBar.style.display = "none";
    if (descBox) descBox.innerHTML = `<span>轤ｹ蜃ｻ髣ｪ蜊｡蜊ｳ蜿ｯ鄙ｻ霓ｬ譟･逵倶ｸｭ譌･蟇ｹ辣ｧ鄙ｻ隸大所驥贋ｹ会ｼ・/span>`;
    
    // Restore normal chapter view
    if (currentSubject === 'itpass') {
      initFlashcards(currentItPassLessonId);
    } else if (currentSubject === 'sg') {
      initFlashcards(currentSgLessonId);
    }
  }
}

function rateAnkiCard(quality) {
  if (ankiQueue.length === 0) return;
  const currentCard = ankiQueue[ankiCurrentIdx];
  
  updateAnkiCardState(currentCard.ja, quality);
  
  // Play micro-animation transition
  const cardElement = document.getElementById("flashcard-element");
  if (cardElement) {
    cardElement.style.transform = "rotateY(180deg) scale(0.92) translateY(-10px)";
    cardElement.style.opacity = "0.6";
    cardElement.style.transition = "all 0.2s cubic-bezier(0.4, 0, 0.2, 1)";
  }
  
  setTimeout(() => {
    buildAnkiQueue();
    renderAnkiCard();
    if (cardElement) {
      cardElement.style.transform = "";
      cardElement.style.opacity = "1";
      cardElement.style.transition = "";
    }
  }, 200);
}

function updateAnkiCardState(jaTerm, quality) {
  const state = loadAnkiCardsState();
  const cardState = state[jaTerm] || {
    interval: 0,
    repetition: 0,
    efactor: 2.5,
    nextReview: 0
  };
  
  if (quality < 3) {
    cardState.repetition = 0;
    cardState.interval = 1; // 1 day
  } else {
    if (cardState.repetition === 0) {
      cardState.interval = 1;
    } else if (cardState.repetition === 1) {
      cardState.interval = 6;
    } else {
      cardState.interval = Math.round(cardState.interval * cardState.efactor);
    }
    cardState.repetition += 1;
  }
  
  cardState.efactor = cardState.efactor + (0.1 - (5 - quality) * (0.08 + (5 - quality) * 0.02));
  if (cardState.efactor < 1.3) cardState.efactor = 1.3;
  
  const now = Date.now() + simulatedTimeOffset;
  cardState.nextReview = now + cardState.interval * 24 * 60 * 60 * 1000;
  
  state[jaTerm] = cardState;
  saveAnkiCardsState(state);
}

function advanceAnkiTime(days) {
  simulatedTimeOffset += days * 24 * 60 * 60 * 1000;
  showToast(`竢ｰ 讓｡諡溯ｰ・ｯ墓慮髣ｴ蜷大錘謗ｨ霑帑ｺ・${days} 螟ｩ・～, "info");
  if (flashcardMode === 'anki') {
    buildAnkiQueue();
    renderAnkiCard();
  }
}

function initItPassCalculators() {
  switchCalculatorTool();
}

function switchCalculatorTool() {
  const select = document.getElementById("calculator-select");
  const container = document.getElementById("tool-inputs-container");
  if (!select || !container) return;

  const tool = select.value;
  if (tool === "binary") {
    container.innerHTML = `
      <div class="tool-row">
        <label for="calc-number-input">謨ｰ蛟､</label>
        <input id="calc-number-input" type="text" value="42" oninput="calculateBinary()">
      </div>
      <div class="tool-result" id="calculator-result"></div>
    `;
    calculateBinary();
    return;
  }

  if (tool === "reliability") {
    container.innerHTML = `
      <div class="tool-row">
        <label for="calc-mtbf-input">MTBF</label>
        <input id="calc-mtbf-input" type="number" min="0" step="1" value="1000" oninput="calculateReliability()">
      </div>
      <div class="tool-row">
        <label for="calc-mttr-input">MTTR</label>
        <input id="calc-mttr-input" type="number" min="0" step="1" value="10" oninput="calculateReliability()">
      </div>
      <div class="tool-result" id="calculator-result"></div>
    `;
    calculateReliability();
    return;
  }

  container.innerHTML = `
    <div class="tool-row">
      <label for="calc-gain-input">謾ｶ逶・/label>
      <input id="calc-gain-input" type="number" step="1" value="120000" oninput="calculateRoi()">
    </div>
    <div class="tool-row">
      <label for="calc-cost-input">謚戊ｵ・｢・/label>
      <input id="calc-cost-input" type="number" step="1" value="80000" oninput="calculateRoi()">
    </div>
    <div class="tool-result" id="calculator-result"></div>
  `;
  calculateRoi();
}

function calculateBinary() {
  const input = document.getElementById("calc-number-input");
  const result = document.getElementById("calculator-result");
  if (!input || !result) return;

  const raw = input.value.trim();
  let decimal = Number.parseInt(raw, 10);
  if (/^0b[01]+$/i.test(raw)) decimal = Number.parseInt(raw.slice(2), 2);
  if (/^0x[0-9a-f]+$/i.test(raw)) decimal = Number.parseInt(raw.slice(2), 16);

  if (!Number.isFinite(decimal)) {
    result.innerHTML = "譛画譜謨ｰ蟄励ｒ蜈･蜉帙＠縺ｦ縺上□縺輔＞縲・;
    return;
  }

  result.innerHTML = `
    <strong>10霑帛宛:</strong> ${decimal}<br>
    <strong>2霑帛宛:</strong> ${decimal.toString(2)}<br>
    <strong>16霑帛宛:</strong> ${decimal.toString(16).toUpperCase()}
  `;
}

function calculateReliability() {
  const mtbf = Number(document.getElementById("calc-mtbf-input")?.value || 0);
  const mttr = Number(document.getElementById("calc-mttr-input")?.value || 0);
  const result = document.getElementById("calculator-result");
  if (!result) return;

  const denominator = mtbf + mttr;
  if (mtbf < 0 || mttr < 0 || denominator <= 0) {
    result.innerHTML = "MTBF 縺ｨ MTTR 縺ｯ 0 莉･荳翫〒蜈･蜉帙＠縺ｦ縺上□縺輔＞縲・;
    return;
  }

  const availability = mtbf / denominator;
  result.innerHTML = `
    <strong>遞ｼ蜒咲紫:</strong> ${(availability * 100).toFixed(3)}%<br>
    <strong>蜈ｬ蠑・</strong> MTBF / (MTBF + MTTR)
  `;
}

function calculateRoi() {
  const gain = Number(document.getElementById("calc-gain-input")?.value || 0);
  const cost = Number(document.getElementById("calc-cost-input")?.value || 0);
  const result = document.getElementById("calculator-result");
  if (!result) return;

  if (cost === 0) {
    result.innerHTML = "謚戊ｵ・｢昜ｸ崎・荳ｺ 0縲・;
    return;
  }

  const roi = (gain - cost) / cost;
  result.innerHTML = `
    <strong>ROI:</strong> ${(roi * 100).toFixed(2)}%<br>
    <strong>謾ｶ逶・- 謚戊ｵ・｢・</strong> ${(gain - cost).toLocaleString()}
  `;
}

