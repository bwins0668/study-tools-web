// Local Simulator for custom simple assignments and loops
function runLocalSimulateTrace(language, code) {
  const steps = [];
  const variables = {};
  const heap = {};
  let stdout = "";
  
  const lines = code.split('\n');
  
  try {
    for (let i = 0; i < lines.length; i++) {
      const lineNum = i + 1;
      const rawLine = lines[i].trim();
      if (!rawLine) continue;
      
      let isLoopStart = false;
      let loopMax = 0;
      let varName = 'i';
      
      const pyLoopMatch = rawLine.match(/for\s+(\w+)\s+in\s+range\(\s*(\d+)\s*\):/);
      const jLoopMatch = rawLine.match(/for\s*\(\s*int\s+(\w+)\s*=\s*0\s*;\s*\1\s*<\s*(\d+)\s*;\s*\1\s*\+\+\s*\)/);
      
      if (pyLoopMatch) {
        isLoopStart = true;
        varName = pyLoopMatch[1];
        loopMax = parseInt(pyLoopMatch[2]);
      } else if (jLoopMatch) {
        isLoopStart = true;
        varName = jLoopMatch[1];
        loopMax = parseInt(jLoopMatch[2]);
      }
      
      if (isLoopStart) {
        const bodyLines = [];
        let j = i + 1;
        if (language === 'python') {
          while (j < lines.length && (lines[j].startsWith('    ') || lines[j].startsWith('\t') || lines[j].trim() === "")) {
            if (lines[j].trim() !== "") {
              bodyLines.push({ lineNum: j + 1, content: lines[j].trim() });
            }
            j++;
          }
        } else {
          let braceCount = 0;
          if (rawLine.includes('{')) braceCount++;
          while (j < lines.length) {
            const l = lines[j].trim();
            if (l.includes('{')) braceCount++;
            if (l.includes('}')) braceCount--;
            bodyLines.push({ lineNum: j + 1, content: l.replace(/[{}]/g, '').trim() });
            if (braceCount <= 0 && l.includes('}')) break;
            j++;
          }
        }
        
        for (let stepVal = 0; stepVal < Math.min(loopMax, 8); stepVal++) {
          variables[varName] = stepVal;
          steps.push({
            line: lineNum,
            variables: JSON.parse(JSON.stringify(variables)),
            heap: JSON.parse(JSON.stringify(heap)),
            stdout: stdout,
            explanation: `蠕ｪ邇ｯ蠑蟋具ｼ悟ｽ灘燕 ${varName} = ${stepVal}`
          });
          
          for (let bodyLine of bodyLines) {
            if (!bodyLine.content) continue;
            executeStatement(bodyLine.content, variables, heap, bodyLine.lineNum);
          }
        }
        
        i = j - 1;
        continue;
      }
      
      executeStatement(rawLine, variables, heap, lineNum);
    }
  } catch (err) {
    console.error("Local tracer simulation error:", err);
  }
  
  function executeStatement(statement, vars, heap, lineNum) {
    statement = statement.replace(/;$/, '').trim();
    
    // Arrays
    const pyArrMatch = statement.match(/^(\w+)\s*=\s*\[(.*)\]$/);
    const jArrMatch = statement.match(/^(?:int\[\]\s+)?(\w+)\s*=\s*(?:new\s+int\[\])?\s*\{(.*)\}$/);
    
    if (pyArrMatch || jArrMatch) {
      const name = pyArrMatch ? pyArrMatch[1] : jArrMatch[1];
      const itemsStr = pyArrMatch ? pyArrMatch[2] : jArrMatch[2];
      const items = itemsStr.split(',').map(x => parseInt(x.trim())).filter(x => !isNaN(x));
      heap[name] = items;
      vars[name] = `[Array @${name}]`;
      steps.push({
        line: lineNum,
        variables: JSON.parse(JSON.stringify(vars)),
        heap: JSON.parse(JSON.stringify(heap)),
        stdout: stdout,
        explanation: `蛻晏ｧ句喧謨ｰ扈・${name} 蛟ｼ荳ｺ [${items.join(', ')}]`
      });
      return;
    }
    
    // Array item set
    const arrElemMatch = statement.match(/^(\w+)\[([^\]]+)\]\s*=\s*(.+)$/);
    if (arrElemMatch) {
      const name = arrElemMatch[1];
      const idxExpr = arrElemMatch[2].trim();
      const valExpr = arrElemMatch[3].trim();
      
      let idx = parseInt(idxExpr);
      if (isNaN(idx) && idxExpr in vars) idx = vars[idxExpr];
      
      let val = parseInt(valExpr);
      if (isNaN(val) && valExpr in vars) val = vars[valExpr];
      
      if (heap[name] && !isNaN(idx) && idx >= 0 && idx < heap[name].length) {
        heap[name][idx] = val;
        steps.push({
          line: lineNum,
          variables: JSON.parse(JSON.stringify(vars)),
          heap: JSON.parse(JSON.stringify(heap)),
          stdout: stdout,
          explanation: `蟆・焚扈・${name} 邏｢蠑・${idx} 螟・噪蛟ｼ譖ｴ譁ｰ荳ｺ ${val}`
        });
      }
      return;
    }
    
    // Print
    const pyPrintMatch = statement.match(/^print\((.*)\)$/);
    const jPrintMatch = statement.match(/^System\.out\.print(?:ln)?\((.*)\)$/);
    
    if (pyPrintMatch || jPrintMatch) {
      const expr = pyPrintMatch ? pyPrintMatch[1].trim() : jPrintMatch[1].trim();
      let printVal = "";
      
      if (expr.startsWith('"') && expr.endsWith('"')) {
        printVal = expr.slice(1, -1);
      } else if (expr.startsWith("'") && expr.endsWith("'")) {
        printVal = expr.slice(1, -1);
      } else if (expr in vars) {
        printVal = vars[expr];
      } else if (expr in heap) {
        printVal = JSON.stringify(heap[expr]);
      } else {
        printVal = expr;
      }
      
      stdout += printVal + "\n";
      steps.push({
        line: lineNum,
        variables: JSON.parse(JSON.stringify(vars)),
        heap: JSON.parse(JSON.stringify(heap)),
        stdout: stdout,
        explanation: `霎灘・扈捺棡窶・{printVal}窶晏芦扈育ｫｯ`
      });
      return;
    }
    
    // Arithmetic assignments
    const assignMatch = statement.match(/^(?:int\s+)?(\w+)\s*=\s*(.+)$/);
    if (assignMatch) {
      const name = assignMatch[1];
      const expr = assignMatch[2].trim();
      
      let val = 0;
      if (expr.includes('+')) {
        const parts = expr.split('+').map(p => p.trim());
        let sum = 0;
        parts.forEach(p => {
          let v = parseInt(p);
          if (isNaN(v) && p in vars) v = vars[p];
          sum += (v || 0);
        });
        val = sum;
      } else if (expr.includes('-')) {
        const parts = expr.split('-').map(p => p.trim());
        let res = parseInt(parts[0]);
        if (isNaN(res) && parts[0] in vars) res = vars[parts[0]];
        for (let k = 1; k < parts.length; k++) {
          let v = parseInt(parts[k]);
          if (isNaN(v) && parts[k] in vars) v = vars[parts[k]];
          res -= (v || 0);
        }
        val = res;
      } else {
        val = parseInt(expr);
        if (isNaN(val) && expr in vars) val = vars[expr];
        if (isNaN(val) && expr === 'true') val = true;
        if (isNaN(val) && expr === 'false') val = false;
      }
      
      vars[name] = val;
      steps.push({
        line: lineNum,
        variables: JSON.parse(JSON.stringify(vars)),
        heap: JSON.parse(JSON.stringify(heap)),
        stdout: stdout,
        explanation: `襍句ｼ蜿倬㍼ ${name} = ${val}`
      });
      return;
    }
    
    // self accumulate
    const selfAddMatch = statement.match(/^(\w+)\s*\+=\s*(.+)$/);
    if (selfAddMatch) {
      const name = selfAddMatch[1];
      let addVal = parseInt(selfAddMatch[2].trim());
      if (isNaN(addVal) && selfAddMatch[2].trim() in vars) addVal = vars[selfAddMatch[2].trim()];
      if (name in vars) {
        vars[name] += (addVal || 0);
        steps.push({
          line: lineNum,
          variables: JSON.parse(JSON.stringify(vars)),
          heap: JSON.parse(JSON.stringify(heap)),
          stdout: stdout,
          explanation: `邏ｯ蜉蜿倬㍼ ${name} 逧・ｼ・悟ｽ灘燕蛟ｼ荳ｺ ${vars[name]}`
        });
      }
      return;
    }
    
    // self plus
    const plusPlusMatch = statement.match(/^(\w+)\+\+$/);
    if (plusPlusMatch) {
      const name = plusPlusMatch[1];
      if (name in vars) {
        vars[name]++;
        steps.push({
          line: lineNum,
          variables: JSON.parse(JSON.stringify(vars)),
          heap: JSON.parse(JSON.stringify(heap)),
          stdout: stdout,
          explanation: `蜿倬㍼ ${name} 閾ｪ蠅・1・悟ｽ灘燕蛟ｼ荳ｺ ${vars[name]}`
        });
      }
      return;
    }
  }
  
  if (steps.length === 0) {
    steps.push({
      line: 1,
      variables: {},
      heap: {},
      stdout: "",
      explanation: "遞句ｺ丞ｼ蟋区鴬陦・
    });
  }
  
  return steps;
}

// Load Trace Steps from API or Preset or Simulator fallback
async function loadTraceSteps(language, code) {
  const state = stepperState[language];
  state.steps = [];
  state.currentIdx = -1;
  state.isPlaying = false;
  if (state.playTimer) {
    clearInterval(state.playTimer);
    state.playTimer = null;
  }
  
  // Try finding in presets first
  let cleanCode = code.replace(/\s+/g, '').replace(/\r\n/g, '\n');
  let presetKey = null;
  if (cleanCode.includes("intsum=0;for(inti=1;i<=3;i++)sum+=i;System.out.println")) {
    presetKey = "java-sum";
  }
  
  if (presetKey && PRESET_TRACES[presetKey]) {
    state.steps = PRESET_TRACES[presetKey];
    console.log("Loaded trace from static presets.");
    initStepperUi(language);
    return;
  }
  
  // Try API trace
  const apiKey = localStorage.getItem("gemini_api_key") || "";
  try {
    const response = await fetch('/ai/trace', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ code, language, apiKey })
    });
    const data = await response.json();
    if (data.success && data.steps && Array.isArray(data.steps)) {
      state.steps = data.steps;
      console.log("Loaded trace from Gemini AI.");
      initStepperUi(language);
      return;
    }
  } catch (err) {
    console.warn("AI Trace API request failed, fallback to local simulator.", err);
  }
  
  // Fallback to local simulator
  state.steps = runLocalSimulateTrace(language, code);
  console.log("Loaded trace from local simulator.");
  initStepperUi(language);
}

// Initialize Stepper UI Controls
function initStepperUi(lang) {
  const state = stepperState[lang];
  if (state.steps.length === 0) return;
  
  state.currentIdx = 0;
  
  // Reset play icon
  const playIcon = document.getElementById(`${lang}-stepper-play-icon`);
  if (playIcon) {
    playIcon.className = "fa-solid fa-play";
  }
  
  renderStepperStep(lang);
}

// Highlight executing line inside line numbers gutter
function highlightEditorLine(lang, lineNum) {
  const gutterId = `${lang}-line-numbers`;
  const gutter = document.getElementById(gutterId);
  if (!gutter) return;
  
  const spans = gutter.getElementsByTagName("span");
  for (let i = 0; i < spans.length; i++) {
    spans[i].classList.remove("stepper-active-line");
  }
  
  if (lineNum > 0 && lineNum <= spans.length) {
    spans[lineNum - 1].classList.add("stepper-active-line");
    spans[lineNum - 1].scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }
}

// Render Stepper memory states dynamically
let prevStepVars = {};
let prevStepHeap = {};

function renderStepperStep(lang) {
  const state = stepperState[lang];
  if (state.currentIdx < 0 || state.currentIdx >= state.steps.length) return;
  
  const step = state.steps[state.currentIdx];
  
  // Update step progress text
  const counter = document.getElementById(`${lang}-stepper-counter`);
  if (counter) {
    counter.innerText = `豁･謨ｰ: ${state.currentIdx + 1} / ${state.steps.length}`;
  }
  
  // Update editor line highlighting
  highlightEditorLine(lang, step.line);
  
  // Update mini console
  const miniConsole = document.getElementById(`${lang}-stepper-mini-stdout`);
  if (miniConsole) {
    miniConsole.innerText = step.stdout || "・域裏霎灘・・・;
    miniConsole.scrollTop = miniConsole.scrollHeight;
  }
  
  // Update explanation
  const expText = document.getElementById(`${lang}-stepper-explanation`);
  if (expText) {
    expText.innerText = step.explanation || "讓｡諡溽ｨ句ｺ乗鴬陦御ｸｭ...";
  }
  
  // Update variables (Stack Frame)
  const varsList = document.getElementById(`${lang}-stepper-variables`);
  if (varsList) {
    varsList.innerHTML = "";
    const currentVars = step.variables || {};
    
    const varNames = Object.keys(currentVars);
    if (varNames.length === 0) {
      varsList.innerHTML = `<div style="color:var(--text-muted); font-size:11px; text-align:center; padding:10px;">譬亥ｸｧ荳ｺ遨ｺ (No variables)</div>`;
    } else {
      varNames.forEach(name => {
        const val = currentVars[name];
        const prevVal = prevStepVars[name];
        const isChanged = prevVal !== undefined && prevVal !== val;
        
        const card = document.createElement("div");
        card.className = `stepper-variable-card ${isChanged ? 'highlight-change' : ''}`;
        card.innerHTML = `
          <span class="stepper-var-name">${name}</span>
          <span class="stepper-var-val">${val}</span>
        `;
        varsList.appendChild(card);
      });
    }
  }
  
  // Update heap (Arrays & Objects)
  const heapList = document.getElementById(`${lang}-stepper-heap`);
  if (heapList) {
    heapList.innerHTML = "";
    const currentHeap = step.heap || {};
    const heapNames = Object.keys(currentHeap);
    
    if (heapNames.length === 0) {
      heapList.innerHTML = `<div style="color:var(--text-muted); font-size:11px; text-align:center; padding:10px;">蝣・・蟄倅ｸｺ遨ｺ (No objects)</div>`;
    } else {
      heapNames.forEach(name => {
        const arr = currentHeap[name];
        const prevArr = prevStepHeap[name] || [];
        const isArrayChanged = JSON.stringify(arr) !== JSON.stringify(prevArr);
        
        const wrapper = document.createElement("div");
        wrapper.className = `heap-array-wrapper ${isArrayChanged ? 'highlight-change' : ''}`;
        
        let slotsHtml = "";
        arr.forEach((val, idx) => {
          const prevVal = prevArr[idx];
          const isCellChanged = prevVal !== undefined && prevVal !== val;
          slotsHtml += `
            <div class="heap-array-slot ${isCellChanged ? 'highlight-cell-change' : ''}">
              <span class="slot-index">${idx}</span>
              <span class="slot-val">${val}</span>
            </div>
          `;
        });
        
        wrapper.innerHTML = `
          <div class="heap-array-title">
            <span>Array: ${name}</span>
            <span style="color:var(--text-muted);">Length: ${arr.length}</span>
          </div>
          <div class="heap-array-slots">
            ${slotsHtml}
          </div>
        `;
        heapList.appendChild(wrapper);
      });
    }
  }
  
  // Keep states for checking updates in the next step
  prevStepVars = JSON.parse(JSON.stringify(step.variables || {}));
  prevStepHeap = JSON.parse(JSON.stringify(step.heap || {}));
}

// Controller Actions
function prevStepperStep(lang) {
  const state = stepperState[lang];
  if (state.currentIdx > 0) {
    state.currentIdx--;
    renderStepperStep(lang);
  }
}

function nextStepperStep(lang) {
  const state = stepperState[lang];
  if (state.currentIdx < state.steps.length - 1) {
    state.currentIdx++;
    renderStepperStep(lang);
  } else {
    // End of steps
    stopPlayStepper(lang);
  }
}

function stopPlayStepper(lang) {
  const state = stepperState[lang];
  state.isPlaying = false;
  if (state.playTimer) {
    clearInterval(state.playTimer);
    state.playTimer = null;
  }
  const playIcon = document.getElementById(`${lang}-stepper-play-icon`);
  if (playIcon) {
    playIcon.className = "fa-solid fa-play";
  }
}

function togglePlayStepper(lang) {
  const state = stepperState[lang];
  if (state.isPlaying) {
    stopPlayStepper(lang);
  } else {
    state.isPlaying = true;
    const playIcon = document.getElementById(`${lang}-stepper-play-icon`);
    if (playIcon) {
      playIcon.className = "fa-solid fa-pause";
    }
    
    // Automatically reset to start if at the end
    if (state.currentIdx >= state.steps.length - 1) {
      state.currentIdx = 0;
      renderStepperStep(lang);
    }
    
    state.playTimer = setInterval(() => {
      nextStepperStep(lang);
    }, 1200); // 1.2 seconds speed
  }
}

/* ====================================================
   Theme Toggle (Dark / Light)
   ==================================================== */

function toggleTheme() {
  const body = document.body;
  const isLight = body.getAttribute('data-theme') === 'light';
  const btn = document.getElementById('theme-toggle-btn');
  const icon = btn ? btn.querySelector('i') : null;

  if (isLight) {
    body.removeAttribute('data-theme');
    localStorage.setItem('study-tools-theme', 'dark');
    if (icon) icon.className = 'fa-solid fa-sun';
  } else {
    body.setAttribute('data-theme', 'light');
    localStorage.setItem('study-tools-theme', 'light');
    if (icon) icon.className = 'fa-solid fa-moon';
  }
}

function initTheme() {
  const saved = localStorage.getItem('study-tools-theme');
  const btn = document.getElementById('theme-toggle-btn');
  const icon = btn ? btn.querySelector('i') : null;

  if (saved === 'light') {
    document.body.setAttribute('data-theme', 'light');
    if (icon) icon.className = 'fa-solid fa-moon';
  } else {
    document.body.removeAttribute('data-theme');
    if (icon) icon.className = 'fa-solid fa-sun';
  }
}

